# Copy this to .env.local and fill in your values.

# Supabase — Dashboard > Project Settings > API
REACT_APP_SUPABASE_URL=https://your-project-ref.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your-anon-key-here

# USDA FoodData Central — free key at https://fdc.nal.usda.gov/api-key-signup.html
# Omit to use DEMO_KEY (30 req/hr). A free registered key allows 1,000 req/hr.
REACT_APP_USDA_API_KEY=your-usda-key-here

# Web Push (HR Roster publish/shift-swap notifications) — public half of the VAPID keypair only.
# Generate with `npx web-push generate-vapid-keys`; the private half is a Supabase Edge Function
# secret (VAPID_PRIVATE_KEY), never here.
REACT_APP_VAPID_PUBLIC_KEY=your-vapid-public-key-here
